# Copy to .env.local for local development.
# NEVER commit .env.local or real tokens. Only empty placeholders belong in git.

# TxLINE (live mode — optional; replay / demo works with these blank)
TXLINE_API_ORIGIN=https://txline.txodds.com
TXLINE_API_TOKEN=
TXLINE_JWT=
TXLINE_FIXTURE_ID=

# Public fixture id for the lobby live button (not a secret — visible in the browser)
NEXT_PUBLIC_TXLINE_FIXTURE_ID=

# Vercel KV / Upstash (optional — leaderboard falls back to localStorage)
KV_REST_API_URL=
KV_REST_API_TOKEN=
